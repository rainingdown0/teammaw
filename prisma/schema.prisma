// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique @db.VarChar(30)
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  teams      Team[]
  changelogs Changelog[]
  likes      TeamLike[]
}

model Team {
  id        String   @id @default(cuid())
  userId    String
  replicaId String? // optional Champions team ID
  name      String
  notes     String?
  isPublic  Boolean  @default(false)
  isLegal   Boolean  @default(false)
  format    String   @default("m-a")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pokemon TeamPokemon[]
  likes   TeamLike[]
}

model TeamPokemon {
  id        String  @id @default(cuid())
  teamId    String
  slot      Int // 1-6
  pokemonId String
  nickname  String?
  teraType  String? // nullable until Tera returns
  abilityId String
  itemId    String?
  nature    String
  evHp      Int // min 0 max 32
  evAtk     Int
  evDef     Int
  evSpa     Int
  evSpd     Int
  evSpe     Int

  team  Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  moves TeamPokemonMove[]

  @@unique([teamId, slot])
}

model TeamPokemonMove {
  id            String @id @default(cuid())
  teamPokemonId String
  slot          Int // 1-4
  moveId        String

  teamPokemon TeamPokemon @relation(fields: [teamPokemonId], references: [id], onDelete: Cascade)

  @@unique([teamPokemonId, slot])
}

model TeamLike {
  id     String @id @default(cuid())
  teamId String
  userId String

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId]) // prevents a user liking the same team twice
}

model Changelog {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
