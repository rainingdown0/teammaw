// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// pnpx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique @db.VarChar(30)
  email     String   @unique @db.VarChar(255)
  password  String   @db.VarChar(255)
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  teams      Team[]
  changelogs Article[]
  likes      TeamLike[]
}

model Team {
  id        String   @id @default(cuid())
  userId    String
  replicaId String?  @db.VarChar(10)
  name      String   @db.VarChar(64)
  notes     String?  @db.Text
  isPublic  Boolean  @default(false)
  isLegal   Boolean  @default(false)
  format    String   @default("m-a") @db.VarChar(20)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  pokemon TeamPokemon[]
  likes   TeamLike[]
}

model TeamPokemon {
  id        String  @id @default(cuid())
  teamId    String
  slot      Int // 1-6
  pokemonId String  @db.VarChar(50)
  nickname  String? @db.VarChar(18)
  teraType  String? @db.VarChar(15)
  abilityId String  @db.VarChar(50)
  itemId    String? @db.VarChar(50)
  nature    String  @db.VarChar(15)
  evHp      Int // min 0 max 32
  evAtk     Int
  evDef     Int
  evSpa     Int
  evSpd     Int
  evSpe     Int

  team  Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  moves TeamPokemonMove[]

  @@unique([teamId, slot])
}

model TeamPokemonMove {
  id            String @id @default(cuid())
  teamPokemonId String
  slot          Int // 1-4
  moveId        String @db.VarChar(50)

  teamPokemon TeamPokemon @relation(fields: [teamPokemonId], references: [id], onDelete: Cascade)

  @@unique([teamPokemonId, slot])
}

model TeamLike {
  id     String @id @default(cuid())
  teamId String
  userId String

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId]) // prevents a user liking the same team twice
}

model Article {
  id        String   @id @default(cuid())
  userId    String
  title     String   @db.VarChar(150)
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
